{
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/editor",
            "destination": "/editor/index.html"
        },
        {
            "source": "/editor/(.*)",
            "destination": "/editor/index.html"
        },
        {
            "source": "/((?!editor).*)",
            "destination": "/index.html"
        }
    ]
}